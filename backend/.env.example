# Copy to .env and fill in values for local development / deployment.
# NEVER commit .env — it is gitignored.

# --- Cursor Cloud Agents API ---
# Get a key: https://cursor.com/dashboard/integrations
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5
CURSOR_TIMEOUT_SECONDS=120
CURSOR_POLL_INTERVAL_SECONDS=2

# --- Gmail IMAP (no OAuth — use an app password) ---
# Setup:
#   1. Gmail → Settings → See all settings → Forwarding and POP/IMAP → Enable IMAP
#   2. Google Account → Security → 2-Step Verification ON
#   3. App passwords → create for "Mail" → paste 16-char password below
#   4. Spaces in the displayed password are OK (stripped automatically)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_MAX_MESSAGES=80

# --- Background inbox watcher ---
INBOX_POLL_ENABLED=true
INBOX_POLL_INTERVAL_SECONDS=120

# --- CORS (production) ---
# Comma-separated frontend URLs after Vercel deploy, e.g.:
# CORS_ORIGINS=https://sloth.vercel.app,https://www.sloth.vercel.app
CORS_ORIGINS=

LOG_LEVEL=INFO
SLOTH_ENV=development
