# Copy to .env and fill in values for local development / deployment.

# AI — OPENAI_API_KEY required for LLM workflow extraction (optional; heuristic fallback used if missing/invalid)
# CURSOR_API_KEY is NOT an OpenAI key and cannot be used for chat completions here.
OPENAI_API_KEY=
CURSOR_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1500

# Live inbox (Gmail app password when 2FA enabled)
IMAP_HOST=imap.gmail.com
IMAP_USER=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_MAX_MESSAGES=80

LOG_LEVEL=INFO
SLOTH_ENV=development
