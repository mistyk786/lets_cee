# Copy to .env and fill in values for local development / deployment.

# Cursor Cloud Agents API (https://cursor.com/dashboard/integrations)
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5
CURSOR_TIMEOUT_SECONDS=120
CURSOR_POLL_INTERVAL_SECONDS=2

# Optional: read real inbox via IMAP (no Gmail OAuth — use an app password)
# Gmail: IMAP_HOST=imap.gmail.com  IMAP_USER=you@gmail.com  IMAP_PASSWORD=xxxx
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_MAX_MESSAGES=80

# Background inbox polling (checks every N seconds while API is running)
INBOX_POLL_ENABLED=true
INBOX_POLL_INTERVAL_SECONDS=120

LOG_LEVEL=INFO
SLOTH_ENV=development
