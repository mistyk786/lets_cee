# SLOTH frontend → backend integration
# Copy to .env.local and adjust for your machine.

# FastAPI backend (no trailing slash)
VITE_API_BASE_URL=http://127.0.0.1:8000

# Set to "true" to force mock data (demo mode without backend)
# VITE_USE_MOCK_API=true

# Watcher status poll interval in milliseconds (default 15000)
# VITE_WATCHER_POLL_MS=15000
